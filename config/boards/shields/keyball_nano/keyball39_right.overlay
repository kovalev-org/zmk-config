#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <behaviors.dtsi>
#include <input/processors.dtsi>

#include "keyball39.dtsi"

&default_transform {
    col-offset = <6>;
};

&kscan0 {
	col-gpios
		= <&pro_micro 4 GPIO_ACTIVE_HIGH>
		, <&pro_micro 5 GPIO_ACTIVE_HIGH>
		, <&pro_micro 6 GPIO_ACTIVE_HIGH>
		, <&pro_micro 7 GPIO_ACTIVE_HIGH>
		, <&pro_micro 8 GPIO_ACTIVE_HIGH>
        , <&pro_micro 9 GPIO_ACTIVE_HIGH>
		;
};

&pinctrl {
    spi1_default: spi1_default {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 1, 13)>,
                <NRF_PSEL(SPIM_MOSI, 0, 10)>,
                <NRF_PSEL(SPIM_MISO, 0, 10)>;
        };
    };

    spi1_sleep: spi1_sleep {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 1, 13)>,
                <NRF_PSEL(SPIM_MOSI, 0, 10)>,
                <NRF_PSEL(SPIM_MISO, 0, 10)>;
            low-power-enable;
        };
    };
};

&spi1 {
    status = "okay";
    compatible = "nordic,nrf-spim";
    pinctrl-0 = <&spi1_default>;
    pinctrl-1 = <&spi1_sleep>;
    pinctrl-names = "default", "sleep";
    cs-gpios = <&gpio0 9 GPIO_ACTIVE_LOW>;

    trackball: trackball@0 {
        status = "okay";
        compatible = "pixart,pmw3610";
        reg = <0>;
        spi-max-frequency = <2000000>;
        // Motion IRQ pin (was `irq-gpios` in the kumamuk-git fork; upstream
        // Zephyr's pixart,pmw3610 binding calls it motion-gpios).
        motion-gpios = <&gpio1 11 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        // Required by upstream binding: map sensor axes to input events.
        // Sensor is mounted rotated 90° relative to user view (sensor +X points
        // "user up", sensor +Y points "user right"), so cross-wire the axes
        // and invert the X mapping. Original kumamuk-git config used
        // CONFIG_PMW3610_ORIENTATION_180=y which did *both* axes but did not
        // also swap — translation to the upstream binding ends up here.
        zephyr,axis-x = <INPUT_REL_Y>;
        zephyr,axis-y = <INPUT_REL_X>;
        invert-x;
        // Was CONFIG_PMW3610_CPI=1200.
        res-cpi = <1200>;
        // Was CONFIG_PMW3610_SMART_ALGORITHM=y.
        smart-mode;
    };
};

// Each &mkp press (LCLK/MCLK/RCLK on the Mouse layer) is also routed
// through ZMK's built-in `mkp_input_listener`. Attaching `zip_temp_layer`
// here re-arms the Mouse layer's deactivation timer to 500 ms on every
// click — so the Mouse layer:
//   - is kept alive long enough for a multi-click (double-/triple-click)
//     because each press reschedules the timer to 500 ms again;
//   - deactivates 500 ms after the last click of a click sequence, which
//     feels effectively immediate to the user but still fits inside
//     standard OS double-click detection windows (250–500 ms).
//
// `zip_temp_layer`'s disable work is keyed on the layer index, and each
// `temp_layer_handle_event` call calls `k_work_reschedule(...)` — so the
// trackball's 3000 ms schedule and this 500 ms schedule don't conflict;
// whichever path fires latest sets the next deactivation time.
&mkp_input_listener {
    input-processors = <&zip_temp_layer 5 500>;
};

/ {
    // Custom WHEEL-only scaler so we can negate vertical scroll (only) without
    // also touching horizontal. Upstream ships zip_scroll_scaler which operates
    // on both WHEEL and HWHEEL — we use that for the symmetric half-speed step
    // and this one for the asymmetric Y-inversion step.
    zip_wheel_scaler: zip_wheel_scaler {
        compatible = "zmk,input-processor-scaler";
        #input-processor-cells = <2>;
        type = <INPUT_EV_REL>;
        codes = <INPUT_REL_WHEEL>;
        track-remainders;
    };

    trackball_listener: trackball_listener {
        compatible = "zmk,input-listener";
        device = <&trackball>;
        // Auto-mouse: every trackball motion event activates the Mouse layer
        // (layer index 5 in base.keymap — `#define MOUSE 5`) for 3000 ms.
        // The Mouse layer's thumb bindings turn the LH0/RH0/RH1 keys into
        // mouse buttons; the layer auto-deactivates 3 s after the last motion
        // (or 500 ms after the last click — see &mkp_input_listener above).
        input-processors = <&zip_temp_layer 5 3000>;

        // Scroll mode: while the Nav layer (index 1, `#define NAV 1`) is
        // active — i.e. while LH1 / `&lt_spc NAV 0` is held — the trackball's
        // X/Y events are remapped to horizontal/vertical wheel events
        // instead of cursor movement, so rolling the ball scrolls.
        // process-next is omitted (default false), so this REPLACES the
        // default auto-mouse chain on this layer — Mouse layer doesn't
        // also activate while you're scrolling.
        scroll {
            layers = <1>;
            // Chain: (1) remap X/Y to HWHEEL/WHEEL,
            //        (2) divide both axes by 5 for a comfortable scroll speed,
            //        (3) negate WHEEL only (vertical) to get natural-direction
            //            scrolling without affecting horizontal.
            // The cell <-1 1> on zip_wheel_scaler multiplies WHEEL by -1.
            input-processors = <
                &zip_xy_to_scroll_mapper
                &zip_scroll_scaler 1 5
                &zip_wheel_scaler (-1) 1
            >;
        };
    };
};
